---
import BaseLayout from '../layouts/BaseLayout.astro';
import { StatsIsland } from '../islands/stats';
import { RecentLoginsIsland } from '../islands/recent-logins';
---

<BaseLayout title="FastLogin - 控制中心" activePage="dashboard">
  <div class="page-header">
    <h1 class="page-title">控制中心</h1>
    <p class="page-subtitle">本地 SSO 快速登录服务管理</p>
  </div>

  <div class="page-content" style="display: flex; flex-direction: column; gap: 24px;">
    <StatsIsland client:load />
    <RecentLoginsIsland client:load />
  </div>
</BaseLayout>
