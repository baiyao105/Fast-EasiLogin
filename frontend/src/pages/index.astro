---
import BaseLayout from '../layouts/BaseLayout.astro';
import { StatsIsland } from '../islands/stats';
---

<BaseLayout title="Fast EasiLogin - 仪表盘" activePage="dashboard">
  <div class="page-header">
    <h1 class="page-title">仪表盘</h1>
    <div class="status-badge running">
      <span class="status-dot"></span>
      服务运行中
    </div>
  </div>
  
  <div class="page-container">
    <StatsIsland client:load />
    
    <div style="margin-top: 24px;">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">最近登录</h2>
        </div>
        <div class="card-content">
          <div class="empty-state">
            <svg class="empty-state-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
              <rect x="9" y="3" width="6" height="4" rx="1"/>
              <path d="M9 14l2 2 4-4"/>
            </svg>
            <div class="empty-state-title">暂无登录记录</div>
            <div class="empty-state-desc">登录记录将在这里显示</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
